---
import { Image } from "astro:assets";

import Navbar from "@/components/Navbar.astro";

import "@/styles/components/header.css";

import isla from "@/assets/isla.png";
---

<header class="site-header">
  <Navbar />
  <Image
    class="header-img"
    src={isla}
    alt="Isla"
    sizes="100px"
    width={100}
    height={100}
    widths={[100, 200, 400, 512]}
  />
</header>
